{
  "info": {
    "name": "Task Flow Challenge",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3333/api" },
    { "key": "token", "value": "" },
    { "key": "taskId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Gabriel Silva\",\n  \"email\": \"gabriel@email.com\",\n  \"password\": \"senha123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.token) pm.collectionVariables.set('token', res.data.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"gabriel@email.com\",\n  \"password\": \"senha123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Criar tarefa",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.id) pm.collectionVariables.set('taskId', res.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/tasks",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Estudar arquitetura hexagonal\",\n  \"description\": \"Ler artigo e ajustar projeto\",\n  \"status\": \"pending\"\n}"
            }
          }
        },
        {
          "name": "Criar múltiplas tarefas",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/tasks/bulk",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tasks\": [\n    { \"title\": \"Tarefa 1\", \"status\": \"pending\" },\n    { \"title\": \"Tarefa 2\", \"status\": \"in_progress\" },\n    { \"title\": \"Tarefa 3\", \"description\": \"Com descrição\", \"status\": \"done\" }\n  ]\n}"
            }
          }
        },
        {
          "name": "Listar status disponíveis",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tasks/status",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Listar tarefas",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tasks",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Buscar tarefa por ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tasks/{{taskId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Atualizar tarefa",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/tasks/{{taskId}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Título atualizado\",\n  \"status\": \"in_progress\"\n}"
            }
          }
        },
        {
          "name": "Deletar tarefa",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/tasks/{{taskId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    }
  ]
}
